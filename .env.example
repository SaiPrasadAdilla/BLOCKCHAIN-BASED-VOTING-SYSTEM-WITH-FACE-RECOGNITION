# MongoDB Configuration
MONGO_USER=app_user
MONGO_ROOT_PASSWORD=admin123
MONGO_DB=app_backend
MONGO_URL=mongodb://app_user:app_password@mongodb:27017

# Ethereum Configuration
ETHEREUM_NETWORK=goerli
ETHEREUM_RPC_URL=http://ethereum:8545
ETHEREUM_PASSWORD=password
ETHEREUM_ACCOUNT_PASSWORD=password123

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=1d

# App
NODE_ENV=production
PORT=3000

# Microservices (internal, exposed in container)
BLOCKCHAIN_SERVICE_HOST=0.0.0.0
BLOCKCHAIN_SERVICE_PORT=3001
FACIAL_RECOGNITION_SERVICE_HOST=0.0.0.0
FACIAL_RECOGNITION_SERVICE_PORT=3002